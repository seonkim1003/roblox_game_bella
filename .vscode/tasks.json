{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Roblox: Validate",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\validate.ps1"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Roblox: Serve",
      "type": "shell",
      "command": "${env:USERPROFILE}\\.rokit\\bin\\rojo.exe",
      "args": [
        "serve",
        "${workspaceFolder}\\default.project.json"
      ],
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
